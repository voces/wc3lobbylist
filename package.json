{
	"name": "w3xio",
	"version": "1.0.0",
	"description": "",
	"main": "dist/src/index.js",
	"scripts": {
		"build": "tsc --project tsconfig.build.json",
		"debug": "node --no-warnings --inspect-brk dist/src/index.js",
		"dev": "tsc --project tsconfig.build.json --watch",
		"lint": "eslint src --ext .js,.ts,.jsx,.tsx --quiet --fix",
		"start-debug": "node --inspect-brk --no-warnings dist/src/index.js",
		"start": "node --no-warnings dist/src/index.js",
		"test-debug": "node --inspect-brk node_modules/.bin/jest --runInBand",
		"test-lint": "eslint src --ext .js,.ts,.jsx,.tsx --max-warnings 0",
		"test": "jest",
		"watch": "npm-watch"
	},
	"dependencies": {
		"@types/cors": "^2.8.17",
		"@types/express": "^4.17.21",
		"@types/jest": "^29.5.12",
		"@types/moo": "^0.5.9",
		"@types/morgan": "^1.9.9",
		"@types/node": "^20.12.7",
		"@typescript-eslint/eslint-plugin": "^7.18.0",
		"@typescript-eslint/parser": "^7.18.0",
		"@zerollup/ts-transform-paths": "^1.7.18",
		"cors": "^2.8.5",
		"discord.js": "^14.16.3",
		"eslint": "^8.57.1",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-prettier": "^5.2.1",
		"eslint-plugin-simple-import-sort": "^12.1.1",
		"express": "^4.21.0",
		"jest": "^29.7.0",
		"moo": "^0.5.2",
		"morgan": "^1.10.0",
		"mysql2": "^3.11.4",
		"npm-watch": "^0.13.0",
		"prettier": "^3.3.3",
		"ts-jest": "^29.2.5",
		"typescript": "^5.6.3"
	},
	"watch": {
		"build": "src"
	},
	"author": "verit",
	"license": "MIT",
	"type": "module",
	"engines": {
		"node": ">=18"
	}
}
